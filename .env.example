# Environment Variables — Holocron AI Engineer
# Copie para .env e preencha com seus valores

# Database
DATABASE_URL=postgresql://holocron:holocron@localhost:5432/holocron

# LLM Provider (OpenRouter OU OpenAI — prioriza OpenRouter se definido)
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Modelos (opcional — defaults usam OpenRouter format)
CHAT_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
