{
  "mcpServers": {
    "holocron": {
      "command": "npx",
      "args": ["tsx", "src/mcp/index.ts"],
      "cwd": "${workspaceFolder}",
      "env": {
        "DATABASE_URL": "postgresql://holocron:holocron@localhost:5432/holocron",
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}"
      }
    }
  }
}
