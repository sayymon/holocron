{
  "name": "holocron-ai-engineer",
  "version": "0.1.0",
  "description": "Tutor inteligente personalizado para o curso de Engenharia de IA Aplicada",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "build": "tsc",
    "mcp": "tsx src/mcp/index.ts",
    "cli": "tsx src/cli.ts",
    "index": "tsx src/cli.ts index",
    "search": "tsx src/cli.ts search",
    "ask": "tsx src/cli.ts ask",
