    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "openai": "^6.39.0",
    "pg": "^8.21.0",
    "pgvector": "^0.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
